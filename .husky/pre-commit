#!/usr/bin/env sh
set -eu
cd "$(git rev-parse --show-toplevel)"
if [ -z "$(git diff --cached --name-only --diff-filter=ACMR)" ]; then
  echo "→ no staged files; skipping pre-commit verification"
  exit 0
fi
echo "→ staged whitespace/conflict-marker check"
git diff --cached --check
echo "→ checks"
bun run check
