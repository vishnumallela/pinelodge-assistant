{
  "name": "@pinelodge/api-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "oxlint .",
    "format": "oxfmt . --ignore-path ../../.prettierignore",
    "format:check": "oxfmt . --check --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules"
  },
  "dependencies": {
    "@pinelodge/api-gateway": "workspace:*"
  },
  "peerDependencies": {
    "@orpc/server": "*",
    "@orpc/client": "*"
  }
}
