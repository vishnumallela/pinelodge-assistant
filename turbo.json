{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "tsconfig.base.json",
    ".oxlintrc.json",
    ".oxfmtrc.toml",
    ".prettierignore",
    ".editorconfig"
  ],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL_APP",
    "DATABASE_URL_AUTH",
    "REDIS_URL",
    "XAI_API_KEY",
    "GROK_REALTIME_MODEL",
    "GROK_REALTIME_VOICE",
    "XAI_SUMMARY_MODEL",
    "XAI_SIP_WEBHOOK_SECRET",
    "TWILIO_AUTH_TOKEN",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "AUTH_TRUSTED_ORIGINS",
    "COOKIE_DOMAIN",
    "API_PORT",
    "AUTH_PORT",
    "FRONTEND_PORT",
    "VITE_API_URL",
    "VITE_AUTH_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/.env.example", "!**/dist/**"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/dist/**"],
      "outputs": []
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "!**/dist/**", "!**/*.md"],
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "format:check": {
      "inputs": ["$TURBO_DEFAULT$", "!**/dist/**"],
      "outputs": []
    },
    "check": {
      "dependsOn": ["typecheck", "lint", "format:check"]
    },
    "db:migrate": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
