# @pinelodge/auth — service env
NODE_ENV=development
AUTH_PORT=3001

# Identity store (this service owns the auth database)
DATABASE_URL_AUTH=postgres://pinelodge:pinelodge@localhost:5444/pinelodge_auth

# Auth secrets (min 16 chars)
BETTER_AUTH_SECRET=change-me-min-16-chars
BETTER_AUTH_URL=http://localhost:3001

# Origins allowed to call the auth service
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3002
# COOKIE_DOMAIN=

# Admin identities (seeded on boot; sign-ups disabled).
# ADMIN_USERS adds admins beyond the primary pair as comma-separated
# email:password entries.
ADMIN_EMAIL=vishnu@stackaisolutions.com
ADMIN_PASSWORD=password1234
# ADMIN_USERS=second-admin@example.com:change-me-password
