# @pinelodge/api-gateway — service env
NODE_ENV=development
API_PORT=3002

# App database (calls, transcripts, summaries)
DATABASE_URL_APP=postgres://pinelodge:pinelodge@localhost:5443/pinelodge_app

# Redis backing the BullMQ summarization queue
REDIS_URL=redis://localhost:6379

# Auth service (session resolution)
BETTER_AUTH_URL=http://localhost:3001
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# xAI: Grok realtime voice answers the live call; a text model writes the summary
XAI_API_KEY=
GROK_REALTIME_MODEL=grok-voice-think-fast-1.0
GROK_REALTIME_VOICE=ara
XAI_SUMMARY_MODEL=grok-4.3

# Facility identity: staff schedules evaluate in this timezone
FACILITY_NAME=Pine Lodge Assisted Living
FACILITY_TIMEZONE=America/Chicago

# SIP (optional): signing secret from the xAI Direct SIP number registration.
# Setting it enables POST /api/sip/incoming; the SIP session authenticates
# with XAI_API_KEY. Point carriers at sip:{number}@sip.voice.x.ai;transport=tls
# XAI_SIP_WEBHOOK_SECRET=

# Twilio bridge (optional): your Twilio account Auth Token. Enables
# POST /api/twilio/incoming (voice webhook) + the media-stream WebSocket.
# Point a Twilio number's "A call comes in" webhook at /api/twilio/incoming.
# TWILIO_AUTH_TOKEN=

# Single-admin application: only this identity may use the dashboard
ADMIN_EMAIL=vishnu@stackaisolutions.com

# Observability (optional): OpenObserve-compatible JSON ingest for call events
# OBSERVE_URL=http://localhost:5080
# OBSERVE_ORG=default
# OBSERVE_USER=admin@pinelodge.local
# OBSERVE_PASSWORD=observe1234
