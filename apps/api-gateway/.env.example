# @pinelodge/api-gateway — service env
NODE_ENV=development
API_PORT=3002

# App database (calls, transcripts, summaries)
DATABASE_URL_APP=postgres://pinelodge:pinelodge@localhost:5443/pinelodge_app

# Redis backing the BullMQ summarization queue
REDIS_URL=redis://localhost:6379

# Auth service (session resolution)
BETTER_AUTH_URL=http://localhost:3001
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# xAI: Grok realtime voice answers the live call; a text model writes the summary
XAI_API_KEY=
GROK_REALTIME_MODEL=grok-voice-think-fast-1.0
GROK_REALTIME_VOICE=ara
XAI_SUMMARY_MODEL=grok-4.3

# Seed identity for the default center created on first boot. After that,
# centers (name, timezone, phone number) are managed in the dashboard at
# /centers — these two are never read again.
FACILITY_NAME=Pine Lodge Assisted Living
FACILITY_TIMEZONE=America/Chicago

# Twilio bridge (optional): your Twilio account Auth Token. Enables
# POST /api/twilio/incoming (voice webhook) + the media-stream WebSocket.
# The dialed number routes the call to its center (configured at /centers);
# unmatched numbers land on the default center.
# TWILIO_AUTH_TOKEN=
# Twilio number management (optional): add the Account SID and each center
# can search, buy, and wire up its own number from /centers — list owned
# numbers, purchase with the webhook pre-pointed, re-sync, or release.
# TWILIO_ACCOUNT_SID=

# Transfer briefs (optional): SMTP relay used to email a staff member the
# moment a call transfers to them. SMTP_HOST + EMAIL_FROM enable the feature;
# auth is optional for IP-allowlisted relays. SMTP_SECURE=true for port 465.
# When credentials are set on a STARTTLS port, the TLS upgrade is required —
# the relay must support STARTTLS or sends fail rather than go plaintext.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_AUTH_METHOD=login   # or "plain"; Office 365 only accepts login
# EMAIL_FROM="Sarah at Pine Lodge <sarah@pinelodge.example>"
# Dashboard origin for the "View the full call" link in emails
# (defaults to the first AUTH_TRUSTED_ORIGINS entry)
# APP_URL=http://localhost:3000

# Admin allowlist: only these identities may use the dashboard.
# ADMIN_EMAILS adds admins beyond ADMIN_EMAIL, comma-separated.
ADMIN_EMAIL=vishnu@stackaisolutions.com
ADMIN_EMAILS=ravi@stackaisolutions.com,ashok@theranow.com
