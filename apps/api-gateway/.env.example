# @pinelodge/api-gateway — service env
NODE_ENV=development
API_PORT=3002

# App database (staff, calls, transcripts, reports)
DATABASE_URL_APP=postgres://pinelodge:pinelodge@localhost:5443/pinelodge_app

# Auth service (session resolution)
BETTER_AUTH_URL=http://localhost:3001
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# OpenAI: gpt-realtime answers the live call over WebRTC; the lower-cost
# summary model writes the post-call report. One key covers both.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=shimmer
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_SUMMARY_MODEL=gpt-5-mini

# Facility identity
FACILITY_NAME=Pine Lodge Assisted Living
FACILITY_TIMEZONE=America/Chicago

# Optional: finished call reports are POSTed here as JSON (e.g. a Zapier/n8n
# hook that emails them). Leave unset to disable.
# CALL_REPORT_WEBHOOK_URL=
