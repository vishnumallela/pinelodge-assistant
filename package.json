{
  "name": "pinelodge-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": ["apps/*"],
  "packageManager": "bun@1.3.7",
  "scripts": {
    "prepare": "husky || true",
    "kill:ports": "bash scripts/kill-ports.sh",
    "predev": "bun run kill:ports",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "oxlint . --fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "check": "turbo run typecheck lint format:check",
    "db:up": "docker compose up -d postgres-auth",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres-auth",
    "db:migrate": "turbo run db:migrate",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "latest",
    "typescript": "^5.6.0"
  }
}
